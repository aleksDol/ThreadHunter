{
    "name":  "expert-comment-ai",
    "private":  true,
    "version":  "0.1.0",
    "workspaces":  [
                       "apps/*",
                       "packages/*"
                   ],
    "scripts":  {
                    "install":  "node -e \"console.log(\u0027Use: npm install\u0027)\"",
                    "dev":  "npm run dev --workspaces --if-present",
                    "db:generate":  "npm run db:generate -w @expert-comment-ai/db",
                    "db:migrate":  "npm run db:migrate -w @expert-comment-ai/db",
                    "db:studio":  "npm run db:studio -w @expert-comment-ai/db",
                    "lint":  "npm run lint --workspaces --if-present",
                    "typecheck":  "npm run typecheck --workspaces --if-present"
                }
}
